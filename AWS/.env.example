# ─────────────────────────────────────────────────────────────
# backend/.env.example
# Copy to .env for local development.
# In AWS, all these are injected from Secrets Manager — never set here in prod.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# ─── Database (local Docker) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=ironlog
DB_PASSWORD=ironlog
DB_NAME=ironlog
DB_SSL=false

# ─── Redis (local Docker) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
# REDIS_AUTH_TOKEN=     # Only needed in production

# ─── JWT (generate with: openssl rand -hex 32) ────────────────
JWT_SECRET=replace_with_64_char_random_string_for_local_dev_only_abc
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string_here
JWT_EXPIRES_IN=1h

# ─── OAuth ────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com

# Get from App Store Connect → Certificates, IDs & Profiles → Identifiers
APPLE_CLIENT_ID=app.ironlog.ios

# ─── AWS (only needed for S3/SES features in dev) ─────────────
AWS_REGION=us-east-1
# Use a local MinIO instance for S3 in development:
S3_MEDIA_BUCKET=ironlog-dev-media
# AWS_ACCESS_KEY_ID=     # Use 'aws configure' or IAM roles instead
# AWS_SECRET_ACCESS_KEY= # Never hardcode credentials

# ─── CDN ──────────────────────────────────────────────────────
# In production this is the CloudFront domain
CDN_DOMAIN=                # Leave empty for local dev

# ─── Email ────────────────────────────────────────────────────
FROM_EMAIL=noreply@ironlog.app
# In development, emails log to console instead of sending

# ─── RevenueCat (webhook) ─────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=replace_with_webhook_secret_from_revenuecat_dashboard

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ─────────────────────────────────────────────────────────────
# frontend/.env.example (dart-define values for Flutter)
# Pass via: flutter run --dart-define-from-file=.env
# ─────────────────────────────────────────────────────────────

# API_BASE_URL=http://localhost:3000
# REVENUECAT_IOS_KEY=appl_xxxxxxxxxx
# REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxx
# ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
# ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
